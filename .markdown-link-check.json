{
  "ignorePatterns": [
    { "pattern": "^http://localhost" },
    { "pattern": "^https?://localhost" },
    { "pattern": "^http://127\\." },
    { "pattern": "^https?://127\\." },
    { "pattern": "^http://0\\.0\\.0\\.0" },
    { "pattern": "^https?://10\\." },
    { "pattern": "^https?://192\\.168\\." },
    { "pattern": "^https?://172\\.(1[6-9]|2[0-9]|3[0-1])\\." },
    { "pattern": "^https?://[^/]+\\.local(/|$)" },
    { "pattern": "^https?://[^/]+\\.internal(/|$)" },
    { "pattern": "^mailto:" },
    { "pattern": "^#" }
  ],
  "replacementPatterns": [
    {
      "pattern": "^/",
      "replacement": "https://docs.lenserfight.com/"
    }
  ],
  "httpHeaders": [
