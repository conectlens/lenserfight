# Local MCP server credentials — never commit this file.
# Source before launching Claude Code or the HTTP server:
#   source .env.mcp.local
export SUPABASE_URL=http://127.0.0.1:54321
export SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
export SUPABASE_ANON_KEY=<your-supabase-anon-key>
export SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
export MCP_TRANSPORT=stdio
# Optional: scope tool calls to your lenser UUID
# export LENSERFIGHT_LENSER_ID=<your-lenser-uuid>
