{
  "name": "auth",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/auth/src",
  "projectType": "application",
  "tags": [
    "type:app",
    "layer:app",
    "scope:public",
    "license:oss"
  ],
  "// targets": "to see all targets run: nx show project auth --web",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/auth",
        "command": "vite build"
      },
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "{workspaceRoot}/dist/apps/auth"
      ]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/auth",
        "command": "vite"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/auth",
        "command": "vitest run"
      },
      "cache": true
    }
  }
}
