{
  "name": "forum",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/forum/src",
  "projectType": "application",
  "tags": [
    "layer:app",
    "surface:community",
    "surface:arena",
    "scope:public",
    "license:oss"
  ],
  "// targets": "to see all targets run: nx show project forum --forum",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/forum",
        "command": "vite build"
      },
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "default",
        "^default",
        {
          "externalDependencies": [
            "vite"
          ]
        }
      ],
      "outputs": [
        "{workspaceRoot}/dist/apps/forum"
      ]
    }
  }
}
