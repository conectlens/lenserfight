{
  "name": "arena",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/arena/src",
  "projectType": "application",
  "tags": [
    "type:app",
    "layer:app",
    "scope:marketing",
    "surface:landing",
    "license:oss"
  ],
  "// targets": "to see all targets run: nx show project arena",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/arena",
        "command": "vite build"
      },
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "default",
        "^default",
        {
          "externalDependencies": ["vite"]
        }
      ],
      "outputs": ["{workspaceRoot}/dist/apps/arena"]
    }
  }
}
