{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/docs/src",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project docs --web",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm exec vitepress dev apps/docs -- --port 3005"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm exec vitepress build apps/docs"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm exec vitepress preview apps/docs -- --port 3005"
      }
    }
  }
}
