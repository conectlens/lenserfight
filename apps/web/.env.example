# ─── Quick Start (file mode — no Supabase) ───────────────────────────────────
# Copy to .env.local and run: pnpm nx run web:serve
DATA_SOURCE=file

# ─── Supabase (client — browser) ─────────────────────────────────────────────
# Required when DATA_SOURCE=supabase
# DATA_SOURCE=supabase
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# ─── Product Edition ──────────────────────────────────────────────────────────
# community (default) | cloud
PRODUCT_EDITION=community

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Dev/test only: skip real auth and network calls
# MOCK=false
# FEATURE_CHALLENGES_TAB=false
# FEATURE_LENSER_ACTIVITY=false
# FEATURE_NOTIFICATIONS=false
# FEATURE_NETWORK_LINKS=false
# FEATURE_AGENTS=false
# FEATURE_BENCHMARK_UI=false
# FEATURE_BILLING_UI=false
# FEATURE_PUBLIC_BATTLES=false
# FEATURE_SUPABASE_INTEGRATION=false
# FEATURE_CRON_SCHEDULING=false
# FEATURE_WAITING_LIST=false
# FEATURE_AGENT_ANALYTICS=false
# FEATURE_CHAINABIT_EXECUTION=false

# ─── URLs ─────────────────────────────────────────────────────────────────────
WEB_BASE_URL=http://localhost:3000
AUTH_BASE_URL=http://localhost:3004
ARENA_URL=http://localhost:3001
STATUS_BASE_URL=http://localhost:3003
DOCS_BASE_URL=http://localhost:3002
API_URL=http://localhost:8786
CHAINABIT_API_URL=http://localhost:8786

# ─── Captcha ──────────────────────────────────────────────────────────────────
# Turnstile widget site key (use test key locally)
CAPTCHA_SITE_KEY=test123

# ─── Analytics (production/cloud only — auto-disabled on localhost) ────────────
PUBLIC_POSTHOG_PROJECT_TOKEN=phc_jOsBkqwLBmICZ5fFzVj3dyRtUuMz3jgKLdmDCWtLD72
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

