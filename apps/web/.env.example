# ─── Quick Start (file mode — no Supabase) ───────────────────────────────────
# Copy to .env.local and run: pnpm nx run web:serve
DATA_SOURCE=file

# ─── Supabase (client — browser) ─────────────────────────────────────────────
# Set in the root .env.local — Vite loads from the workspace root (envDir: '../../').
# Required when DATA_SOURCE=supabase:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Public tunnel to local Supabase (ngrok/Cloudflare) — rewrites signed storage URLs for Copy with Parameters
# SUPABASE_PUBLIC_URL=https://your-tunnel.example.com
# MEDIA_CONTENT_PROXY_ENABLED=true
# MEDIA_INLINE_MAX_BYTES=8388608

# ─── URLs ─────────────────────────────────────────────────────────────────────
WEB_BASE_URL=http://localhost:3000
AUTH_BASE_URL=http://localhost:3004
ARENA_URL=http://localhost:3001
STATUS_BASE_URL=http://localhost:3003
DOCS_BASE_URL=http://localhost:3002
# LenserFight platform API (Hono server). Must NOT be the Supabase/PostgREST URL.
API_URL=http://localhost:8786
# Direct Chainabit API base URL (no version prefix). Used for wallet/me, ai/models, etc.
CHAINABIT_API_URL=https://api.chainabit.com

# ─── Captcha ──────────────────────────────────────────────────────────────────
# Turnstile widget site key (use test key locally)
CAPTCHA_SITE_KEY=test123

# ─── Analytics (production/cloud only — auto-disabled on localhost) ────────────
PUBLIC_POSTHOG_PROJECT_TOKEN=phc_jOsBkqwLBmICZ5fFzVj3dyRtUuMz3jgKLdmDCWtLD72
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Debug ────────────────────────────────────────────────────────────────────
# ENABLE_REPOSITORY_DEBUG=false
# ALLOWED_EXTERNAL_REDIRECT_HOSTS=lenserfight.com,chainabit.com
