# ─── apps/mobile environment variables ────────────────────────────────────────
# Expo requires the EXPO_PUBLIC_ prefix to inline vars into the Metro bundle.
# Copy to .env.local for local dev, .env.production for production builds.
#
# Single source of truth for the local Supabase instance:
#   - apps/web + apps/arena: set SUPABASE_URL / SUPABASE_PUBLISHABLE_KEY in root .env.local
#   - apps/mobile: set the EXPO_PUBLIC_ equivalents here (Expo enforces this prefix)
#
# When developing on a physical device, use your machine's LAN/Tailscale IP
# instead of 127.0.0.1 (localhost does not resolve to your dev machine from a device).

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Local dev: get values from `pnpm supabase start` output.
# Production: get values from Supabase project dashboard.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# ─── Analytics (PostHog) ───────────────────────────────────────────────────────
# Leave empty in local dev to disable tracking.
EXPO_PUBLIC_POSTHOG_PROJECT_TOKEN=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Deep-link / OAuth redirect ────────────────────────────────────────────────
EXPO_PUBLIC_AUTH_REDIRECT_URL=lenserfight://auth/callback

# ─── Service base URLs (optional — defaults below are for production) ──────────
# EXPO_PUBLIC_API_URL=https://api.lenserfight.com
# EXPO_PUBLIC_AUTH_BASE_URL=https://auth.lenserfight.com
# EXPO_PUBLIC_WEB_BASE_URL=https://moon.lenserfight.com
# EXPO_PUBLIC_ARENA_URL=https://lenserfight.com
# EXPO_PUBLIC_DOCS_BASE_URL=https://docs.lenserfight.com
# EXPO_PUBLIC_CHAINABIT_APP_URL=https://app.chainabit.com
# EXPO_PUBLIC_CHAINABIT_API_URL=https://api.chainabit.com
