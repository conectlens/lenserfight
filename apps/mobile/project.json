{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile/src",
  "projectType": "application",
  "tags": [
    "scope:public",
    "license:oss"
  ],
  "// targets": "to see all targets run: nx show project mobile",
  "targets": {
    "serve": {
      "continuous": true,
      "options": {
        "cwd": "apps/mobile",
        "command": "TS_IP=$(tailscale ip -4 2>/dev/null || true); if [ -n \"$TS_IP\" ]; then export REACT_NATIVE_PACKAGER_HOSTNAME=\"$TS_IP\"; fi; expo start --lan --port 8081"
      },
      "executor": "nx:run-commands"
    },
    "test": {
      "command": "jest --config apps/mobile/jest.config.cts --runInBand --forceExit",
      "options": {
        "cwd": "."
      },
      "outputs": ["{workspaceRoot}/coverage/apps/mobile"]
    },
    "export": {
      "command": "expo export --clear --platform android",
      "options": {
        "cwd": "apps/mobile"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "eas-build-preview": {
      "command": "eas build --profile preview --platform all --non-interactive",
      "options": {
        "cwd": "apps/mobile"
      }
    },
    "eas-build-production": {
      "command": "eas build --profile production --platform all --non-interactive",
      "options": {
        "cwd": "apps/mobile"
      }
    },
    "eas-submit": {
      "command": "eas submit --profile production --platform all --non-interactive",
      "options": {
        "cwd": "apps/mobile"
      }
    }
  }
}
