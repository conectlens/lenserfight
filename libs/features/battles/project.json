{
  "name": "feature-battles",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/features/battles/src",
  "projectType": "library",
  "tags": [
    "layer:feature",
    "feature:battles"
  ],
  "// targets": "to see all targets run: nx show project feature-battles --web",
  "targets": {
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../../coverage/libs/features/battles"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.lib.json --noEmit",
        "cwd": "libs/features/battles"
      }
    }
  }
}
