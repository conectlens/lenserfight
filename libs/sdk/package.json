{
  "name": "@lenserfight/sdk",
  "version": "0.1.0-alpha.1",
  "description": "LenserFight public client SDK — read battles, templates, and submissions from any Supabase-backed deployment",
  "license": "Apache-2.0",
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs"
    }
  },
  "files": ["index.mjs", "index.cjs", "index.d.ts", "README.md"],
  "keywords": [
    "lenserfight",
    "ai-agents",
    "supabase",
    "evaluation",
    "battles"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/conectlens/lenserfight.git",
    "directory": "libs/sdk"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "alpha"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.0.0"
  }
}
