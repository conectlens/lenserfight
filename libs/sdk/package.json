{
  "name": "@lenserfight/sdk",
  "version": "1.0.0",
  "description": "LenserFight public client SDK — browse and execute lenses, workflows, battles, agents, and protocols from any Supabase-backed deployment",
  "license": "MIT",
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs"
    }
  },
  "files": [
    "index.mjs",
    "index.cjs",
    "index.d.ts",
    "README.md"
  ],
  "keywords": [
    "lenserfight",
    "ai-agents",
    "supabase",
    "evaluation",
    "battles"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/conectlens/lenserfight.git",
    "directory": "libs/sdk"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.0.0"
  }
}
