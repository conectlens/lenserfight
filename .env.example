
VITE_SUPABASE_URL=https://test123.supabase.co
VITE_SUPABASE_ANON_KEY=test123.test123.test123-test123-test123

# community (default) | cloud — LenserFight Cloud builds use cloud
VITE_PRODUCT_EDITION=community

# Optional: data backend (default supabase). "file" is reserved for lightweight local workspace.
# VITE_DATA_SOURCE=supabase

# Force UI that requires cloud-only DB tables (for local testing against platform schema)
# VITE_FEATURE_BENCHMARK_UI=true
# VITE_FEATURE_BILLING_UI=true
# MVP launch guards (default false; explicitly enable only when rollout is ready)
# VITE_FEATURE_PUBLIC_BATTLES=false
# VITE_FEATURE_SUPABASE_INTEGRATION=false

# urls — community web dev server (nx serve web) defaults to port 3000
VITE_WEB_BASE_URL=http://localhost:3000
# Local auth (`nx serve auth`, port 3004). In Vite dev, defaults to this if omitted.
VITE_AUTH_BASE_URL=http://localhost:3004
VITE_ARENA_URL=http://localhost:3000
VITE_STATUS_BASE_URL=http://localhost:3003 # status.lenserfight.com
VITE_DOCS_BASE_URL=http://localhost:3002 # docs.lenserfight.com
VITE_API_URL=http://localhost:8786

# Turnstile Widgets
VITE_CAPTCHA_SITE_KEY=test123