# ─── Root .env — server-side variables only ───────────────────────────────────
# Frontend apps (apps/web, apps/arena, apps/docs) each have their own .env.example.
# This file covers platform-api, CLI, workers, and Supabase CLI substitution.

# ─── Supabase (server — platform-api, workers) ────────────────────────────────
# Never expose these to the browser.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Platform API ─────────────────────────────────────────────────────────────
# PORT=8786
# CORS_ORIGIN=*
# PLATFORM_API_WORKER_INTERVAL_MS=2000
# PLATFORM_API_WORKER_ONCE=false

# ─── Partner — Chainabit ──────────────────────────────────────────────────────
# Server-side only — used by platform-api, not the browser.
# CHAINABIT_API_URL=https://api.chainabit.com
# CHAINABIT_PARTNER_API_KEY=your-partner-api-key
#
# OAuth 2.0 PKCE public client — register via:
#   POST https://api.chainabit.com/api/v1/partner/oauth-clients
#   { clientName: "LenserFight", clientType: "public",
#     redirectUris: ["https://<platform-api-host>/v1/partners/chainabit/oauth/callback"],
#     grantTypes: ["authorization_code"], allowedScopes: ["email:read","profile:read","wallet:read","execution:run"] }
# The response `clientId` goes here. No client_secret — PKCE replaces it.
# CHAINABIT_CLIENT_ID=<uuid-returned-by-POST-partner/oauth-clients>
# CHAINABIT_OAUTH_REDIRECT_URI=https://<platform-api-host>/v1/partners/chainabit/oauth/callback
#
# Supabase CLI env substitution
# SUPABASE_AUTH_CHAINABIT_CLIENT_ID=your-client-id
# SUPABASE_AUTH_CHAINABIT_SECRET=your-client-secret

# ─── LenserFight Cloud / CLI ──────────────────────────────────────────────────
# LENSERFIGHT_API_KEY=lf_replace_me
# LENSERFIGHT_DEVELOPER_TOKEN=lf_replace_me
# LENSERFIGHT_DEVELOPER_TOKEN_EXPIRES_AT=
# LENSERFIGHT_OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# ─── AI Providers ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your-gemini-api-key

# ─── Analytics ────────────────────────────────────────────────────────────────
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
# POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# POSTHOG_HOST=https://us.i.posthog.com
