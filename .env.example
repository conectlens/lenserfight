# ─── Quick Start (file mode — no Docker, no Supabase) ────────────────────────
# Copy this file to .env.local and run:   pnpm nx run web:serve
# The app boots instantly with local IndexedDB storage.
VITE_DATA_SOURCE=file

# ─── Supabase (client — browser) ─────────────────────────────────────────────
# Required when VITE_DATA_SOURCE=supabase
# VITE_DATA_SOURCE=supabase
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Supabase (server — platform-api, worker) ─────────────────────────────────
# These are server-only; never expose to the browser.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Platform API ─────────────────────────────────────────────────────────────
# Port the platform-api HTTP server listens on (default: 8786)
# PORT=8786
# Allowed CORS origin for the platform-api. Use * for local dev; set exact origin in prod.
# CORS_ORIGIN=*
# Worker polling interval in ms (default: 2000) and one-shot mode (default: false)
# PLATFORM_API_WORKER_INTERVAL_MS=2000
# PLATFORM_API_WORKER_ONCE=false

# ─── Partner — Chainabit ──────────────────────────────────────────────────────
# Required to enable the Chainabit partner provider in the platform-api.
# CHAINABIT_API_URL=https://api.chainabit.com
# CHAINABIT_PARTNER_API_KEY=your-partner-api-key

# ─── LenserFight Cloud / CLI ──────────────────────────────────────────────────
# LENSERFIGHT_API_KEY=lf_replace_me
# LENSERFIGHT_DEVELOPER_TOKEN=lf_replace_me
# LENSERFIGHT_DEVELOPER_TOKEN_EXPIRES_AT=
# LENSERFIGHT_OLLAMA_BASE_URL=http://localhost:11434

# ─── AI Providers ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your-gemini-api-key

# ─── Product Edition ──────────────────────────────────────────────────────────
# community (default) | cloud — LenserFight Cloud builds use cloud
VITE_PRODUCT_EDITION=community

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Dev/test only: skip real auth and network calls (default false)
# VITE_MOCK=false

# Cloud-edition-only surfaces (default false for community; override to test locally)
# VITE_FEATURE_CHALLENGES_TAB=false
# VITE_FEATURE_LENSER_ACTIVITY=false
# VITE_FEATURE_NOTIFICATIONS=false
# VITE_FEATURE_NETWORK_LINKS=false
#
# AI Workspace (Automation Log, Workflows, Schedules tabs on AI lenser profiles).
# Set true in .env.local to test locally. Required steps after enabling:
#   1. Ensure seeds 41–44 are applied (pnpm supabase db reset)
#   2. Log in as a seed user (alice@lenserfight.local)
#   3. Open the workspace switcher in the sidebar and switch to an AI lenser
#   4. Navigate to /lenser/<handle>/wf (Workflows) or /lenser/<handle>/lg (Automation Log)
# VITE_FEATURE_AGENTS=false

# Force UI that requires cloud-only DB tables (for local testing against platform schema)
# VITE_FEATURE_BENCHMARK_UI=true
# VITE_FEATURE_BILLING_UI=true
# MVP launch guards (default false; explicitly enable only when rollout is ready)
# VITE_FEATURE_PUBLIC_BATTLES=false
# VITE_FEATURE_SUPABASE_INTEGRATION=false
# CRON scheduling UI — deferred post-OSS-beta; set true only in cloud or after Wave 2
# VITE_FEATURE_CRON_SCHEDULING=false
# Waiting list gate — defaults to true on cloud, false on community/self-hosted
# VITE_FEATURE_WAITING_LIST=false
# Analytics dashboard: cost/quality/performance charts per agent
# VITE_FEATURE_AGENT_ANALYTICS=false

# ─── URLs ─────────────────────────────────────────────────────────────────────
# community web dev server (nx serve web) defaults to port 3000
VITE_WEB_BASE_URL=http://localhost:3000
# Local auth (`nx serve auth`, port 3004). In Vite dev, defaults to this if omitted.
VITE_AUTH_BASE_URL=http://localhost:3004
VITE_ARENA_URL=http://localhost:3001
VITE_STATUS_BASE_URL=http://localhost:3003
VITE_DOCS_BASE_URL=http://localhost:3002
VITE_API_URL=http://localhost:8786
VITE_CHAINABIT_API_URL=http://localhost:8786

# ─── Captcha ──────────────────────────────────────────────────────────────────
# Turnstile widget site key
VITE_CAPTCHA_SITE_KEY=test123

# ─── Analytics ────────────────────────────────────────────────────────────────
# PostHog — optional; omit to disable.
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://us.i.posthog.com
