# LenserFight local development environment
# Copy to .env.development.local and fill in your values.
# Lines starting with # are comments.

# ---------------------------------------------------------------------------
# Supabase (local instance — auto-populated by `pnpm supabase start`)
# ---------------------------------------------------------------------------
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-start-output
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-from-supabase-start-output

# Public anon key for the web client (same as SUPABASE_ANON_KEY)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-start-output

# Storage CDN base URL (used for media thumbnails)
SUPABASE_STORAGE_URL=http://localhost:54321/storage/v1

# ---------------------------------------------------------------------------
# AI provider keys (optional — set ECHO_PROVIDER=1 to skip all provider calls)
# ---------------------------------------------------------------------------

# Set to 1 to use the built-in echo provider instead of real AI providers.
# All battle responses will be instant placeholder text.
ECHO_PROVIDER=1

# Real provider keys (only needed when ECHO_PROVIDER is not set):
# FAL_API_KEY=your-fal-api-key
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key

# ---------------------------------------------------------------------------
# Platform API
# ---------------------------------------------------------------------------
PLATFORM_API_PORT=3001
PLATFORM_API_CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Chainabit OAuth (server-side — platform-api only)
# Register a public OAuth client in your local Chainabit instance first:
#   POST http://localhost:4000/api/v1/partner/oauth-clients
#   { clientName: "LenserFight Dev", clientType: "public",
#     redirectUris: ["http://localhost:3001/v1/partners/chainabit/oauth/callback"],
#     grantTypes: ["authorization_code"], allowedScopes: ["email:read","profile:read","wallet:read","execution:run"] }
# ---------------------------------------------------------------------------
CHAINABIT_API_URL=http://localhost:4000/api/v1
# CHAINABIT_CLIENT_ID=<uuid-from-POST-partner/oauth-clients>
# CHAINABIT_OAUTH_REDIRECT_URI=http://localhost:3001/v1/partners/chainabit/oauth/callback
# CHAINABIT_PARTNER_API_KEY=your-local-partner-api-key

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
NODE_ENV=development
