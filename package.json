{
  "name": "lenserfight",
  "private": true,
  "version": "0.10.0-alpha.2",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "npx nx serve web",
    "dev:docs": "vitepress dev apps/docs",
    "build": "nx vite:build",
    "preview": "nx vite:preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "release": "standard-version",
    "docs:dev": "vitepress dev apps/docs",
    "docs:build": "vitepress build apps/docs",
    "docs:preview": "vitepress preview apps/docs",
    "mvp:readiness": "node scripts/mvp-launch-readiness.mjs",
    "check:oss-migration": "bash scripts/check-oss-migration-private-schemas.sh",
    "supabase:combine-seeds": "bash supabase/combine-seeds.sh",
    "supabase:db:reset": "bash supabase/combine-seeds.sh && supabase db reset --local --yes",
    "supabase:db:reset:debug": "bash supabase/combine-seeds.sh && supabase db reset --local --yes --debug",
    "supabase:seed:demo": "bash scripts/seed-demo.sh",
    "supabase:local:recover": "bash scripts/supabase-local-recover.sh",
    "supabase:enable-byok-resolver": "bash scripts/enable-byok-dev-resolver.sh",
    "supabase:gen:types": "supabase gen types typescript --local --schema public,lensers,lenses,agents,ai,execution,content,media,tenancy > libs/types/src/lib/database.types.ts",
    "smoke": "bash scripts/smoke.sh",
    "smoke:media": "bash scripts/smoke-media.sh",
    "e2e-battle": "bash scripts/e2e-battle.sh",
    "test:db": "bash scripts/run-pgtap.sh",
    "test:rls": "bash scripts/run-pgtap.sh --filter rls",
    "setup:doctor": "node scripts/setup-doctor.mjs",
    "docs:audit": "node tools/gen-cli-docs.mjs --check && node tools/check-cli-docs.mjs && node tools/verify-openapi.mjs",
    "verify-openapi": "node tools/verify-openapi.mjs",
    "gen-cli-docs": "node tools/gen-cli-docs.mjs",
    "gen-cli-docs:check": "node tools/gen-cli-docs.mjs --check",
    "check-cli-docs": "node tools/check-cli-docs.mjs",
    "sync-mentor-handles": "node tools/sync-mentor-handles.mjs",
    "sync-mentor-handles:check": "node tools/sync-mentor-handles.mjs --check",
    "gen-shortlinks": "node tools/gen-shortlinks.mjs",
    "contribute:check": "pnpm smoke && pnpm docs:audit",
    "health:cron": "node tools/health-cron.mjs",
    "gen:status-page": "node tools/gen-status-page.mjs",
    "announcement:gates": "node tools/announcement-dashboard.mjs",
    "announcement:dashboard": "bash scripts/announcement-dashboard.sh",
    "staging-integrity": "node tools/run-staging-integrity-checklist.mjs"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@expo/metro-config": "~54.0.14",
    "@expo/metro-runtime": "~6.1.2",
    "@fal-ai/client": "^1.9.5",
    "@google/genai": "^1.46.0",
    "@juristr/nx-tailwind-sync": "^0.0.9",
    "@marsidev/react-turnstile": "^1.4.2",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@posthog/react": "^1.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.95.2",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@uiw/react-md-editor": "^4.0.11",
    "@xyflow/react": "^12.10.1",
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "expo": "~54.0.33",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "framer-motion": "^12.23.0",
    "i18next": "^25.10.9",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb": "^8.0.3",
    "lucide-react": "0.344.0",
    "pdf-lib": "^1.17.1",
    "posthog-js": "^1.363.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.6.6",
    "react-markdown": "^9.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "~1.5.3",
    "react-native-web": "~0.21.2",
    "react-router-dom": "6.30.3",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "sonner": "^1.7.4",
    "tslib": "^2.8.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/runtime": "~7.27.6",
    "@eslint/js": "^9.39.4",
    "@expo/cli": "~54.0.23",
    "@nx/esbuild": "22.5.4",
    "@nx/eslint": "^22.6.1",
    "@nx/eslint-plugin": "^22.6.3",
    "@nx/expo": "22.5.4",
    "@nx/jest": "22.5.4",
    "@nx/js": "22.6.0",
    "@nx/node": "22.5.4",
    "@nx/react": "22.6.0",
    "@nx/vite": "22.6.0",
    "@nx/vitest": "22.5.4",
    "@nx/web": "22.6.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.21",
    "@swc/helpers": "~0.5.19",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/react-native": "~13.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.1.1",
    "@vitest/ui": "4.1.1",
    "ajv": "^8.18.0",
    "autoprefixer": "^10.4.27",
    "babel-jest": "^30.3.0",
    "babel-preset-expo": "~54.0.10",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.19.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "jest-expo": "~54.0.17",
    "jest-util": "^30.3.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "mermaid": "^11.13.0",
    "metro-config": "~0.83.5",
    "metro-resolver": "~0.83.5",
    "nx": "22.5.4",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "10.9.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.1",
    "vite-plugin-dts": "~4.5.4",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "4.1.1"
  },
  "nx": {}
}
