{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run test *)",
      "Bash(npm run lint *)",
      "Read(.env.example)",
      "Read(./.env.example)",
      "Read(**/.env.example)"
    ],
    "deny": [
      "Read(.env)",
      "Read(./.env)",
      "Read(**/.env)",
      "Read(.env.local)",
      "Read(./.env.local)",
      "Read(**/.env.local)",
      "Read(.env.development)",
      "Read(./.env.development)",
      "Read(**/.env.development)",
      "Read(.env.development.local)",
      "Read(./.env.development.local)",
      "Read(**/.env.development.local)",
      "Read(.env.test)",
      "Read(./.env.test)",
      "Read(**/.env.test)",
      "Read(.env.test.local)",
      "Read(./.env.test.local)",
      "Read(**/.env.test.local)",
      "Read(.env.production)",
      "Read(./.env.production)",
      "Read(**/.env.production)",
      "Read(.env.production.local)",
      "Read(./.env.production.local)",
      "Read(**/.env.production.local)",
      "Read(**/secrets/**)",
      "Bash(npm run build)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(export *)",
      "Bash(set)",
      "Bash(cat .env*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(netcat *)",
      "Bash(ssh *)",
      "Bash(scp *)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        ".env",
        ".env.*",
        "**/.env",
        "**/.env.*",
        "**/secrets/**"
      ],
      "allowRead": [
        ".env.example",
        "./.env.example",
        "**/.env.example"
      ]
    }
  },
  "extraKnownMarketplaces": {
    "nx-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "nrwl/nx-ai-agents-config"
      }
    }
  },
  "enabledPlugins": {}, 
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
 "teammateMode": "in-process"
}
